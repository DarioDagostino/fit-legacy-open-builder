{
  "buildCommand": "cd ../.. && pnpm --filter fit-legacy-app build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "functions": {
    "api/og.ts": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/og",
      "destination": "/api/og"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
